generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── TENANTS ──────────────────────────────────────────────────
model Tenant {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(200)
  address   String?  @db.VarChar(400)
  phone     String?  @db.VarChar(30)
  email     String?  @db.VarChar(200)
  plan      String   @default("free") @db.VarChar(50)
  active    Boolean  @default(true)
  logoUrl   String?
  rfc       String?  @db.VarChar(20)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users              User[]
  owners             Owner[]
  patients           Patient[]
  appointments       Appointment[]
  medications        Medication[]
  inventoryMovements InventoryMovement[]
  prescriptions      Prescription[]
  consentForms       ConsentForm[]
  invoices           Invoice[]
  systemAlerts       SystemAlert[]
  notifications      Notification[]
  clinicalRecords    ClinicalRecord[]

  @@map("tenants")
}

// ── USERS ─────────────────────────────────────────────────────
model User {
  id           String   @id @default(uuid())
  tenantId     String
  fullName     String   @db.VarChar(200)
  email        String   @db.VarChar(200)
  passwordHash String
  role         UserRole @default(recepcionista)
  cedulaProf   String?  @db.VarChar(20)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointments       Appointment[]
  clinicalRecords    ClinicalRecord[]
  prescriptions      Prescription[]
  consentForms       ConsentForm[]
  inventoryMovements InventoryMovement[]
  invoices           Invoice[]

  @@unique([tenantId, email])
  @@map("users")
}

enum UserRole {
  admin
  veterinario
  recepcionista

  @@map("user_role")
}

// ── OWNERS ────────────────────────────────────────────────────
model Owner {
  id        String   @id @default(uuid())
  tenantId  String
  fullName  String   @db.VarChar(200)
  phone     String?  @db.VarChar(30)
  email     String?  @db.VarChar(200)
  curp      String?  @db.VarChar(20)
  address   String?  @db.VarChar(400)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patients      Patient[]
  notifications Notification[]

  @@map("owners")
}

// ── PATIENTS ──────────────────────────────────────────────────
model Patient {
  id         String         @id @default(uuid())
  tenantId   String
  ownerId    String
  name       String         @db.VarChar(100)
  species    PatientSpecies
  breed      String?        @db.VarChar(100)
  birthDate  DateTime?      @db.Date
  sex        PatientSex?
  sterilized Boolean        @default(false)
  weightKg   Decimal?       @db.Decimal(6, 2)
  status     PatientStatus  @default(activo)
  photoUrl   String?
  microchip  String?        @db.VarChar(50)
  notes      String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  owner           Owner            @relation(fields: [ownerId], references: [id])
  appointments    Appointment[]
  clinicalRecords ClinicalRecord[]
  prescriptions   Prescription[]
  consentForms    ConsentForm[]
  invoices        Invoice[]

  @@map("patients")
}

enum PatientSpecies {
  canino
  felino
  ave
  roedor
  reptil
  otro

  @@map("patient_species")
}

enum PatientSex {
  macho
  hembra

  @@map("patient_sex")
}

enum PatientStatus {
  activo
  seguimiento
  control
  archivado

  @@map("patient_status")
}

// ── APPOINTMENTS ──────────────────────────────────────────────
model Appointment {
  id           String            @id @default(uuid())
  tenantId     String
  patientId    String
  userId       String?
  scheduledAt  DateTime
  type         AppointmentType   @default(consulta_general)
  status       AppointmentStatus @default(pendiente)
  notes        String?
  reminderSent Boolean           @default(false)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patient       Patient        @relation(fields: [patientId], references: [id])
  user          User?          @relation(fields: [userId], references: [id])
  invoiceItems  InvoiceItem[]
  notifications Notification[]

  @@map("appointments")
}

enum AppointmentType {
  consulta_general
  vacunacion
  cirugia
  control
  urgencia
  desparasitacion
  otro

  @@map("appointment_type")
}

enum AppointmentStatus {
  pendiente
  confirmada
  en_espera
  completada
  urgente
  cancelada

  @@map("appointment_status")
}

// ── CLINICAL RECORDS ──────────────────────────────────────────
model ClinicalRecord {
  id            String     @id @default(uuid())
  tenantId      String
  patientId     String
  userId        String?
  appointmentId String?
  visitDate     DateTime   @default(now()) @db.Date
  type          RecordType @default(consulta)
  reason        String?
  diagnosis     String?
  temperature   Decimal?   @db.Decimal(4, 1)
  weightKg      Decimal?   @db.Decimal(6, 2)
  treatment     String?
  notes         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patient      Patient       @relation(fields: [patientId], references: [id])
  user         User?         @relation(fields: [userId], references: [id])
  vaccinations Vaccination[]

  @@map("clinical_records")
}

enum RecordType {
  consulta
  vacunacion
  cirugia
  control
  urgencia
  otro

  @@map("record_type")
}

model Vaccination {
  id               String    @id @default(uuid())
  clinicalRecordId String
  vaccineName      String    @db.VarChar(200)
  lotNumber        String?   @db.VarChar(50)
  nextDoseDate     DateTime? @db.Date
  notes            String?

  clinicalRecord ClinicalRecord @relation(fields: [clinicalRecordId], references: [id], onDelete: Cascade)

  @@map("vaccinations")
}

// ── MEDICATIONS ───────────────────────────────────────────────
model Medication {
  id             String             @id @default(uuid())
  tenantId       String
  name           String             @db.VarChar(200)
  category       MedicationCategory @default(otro)
  presentation   String?            @db.VarChar(100)
  stock          Int                @default(0)
  minStock       Int                @default(0)
  unitPrice      Decimal            @default(0) @db.Decimal(10, 2)
  expirationDate DateTime?          @db.Date
  lotNumber      String?            @db.VarChar(50)
  controlled     Boolean            @default(false)
  active         Boolean            @default(true)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  inventoryMovements InventoryMovement[]
  prescriptionItems  PrescriptionItem[]

  @@map("medications")
}

enum MedicationCategory {
  antibiotico
  antiinflamatorio
  anestesico
  anestesico_inhalado
  biologico
  antiparasitario
  hormonal
  otro

  @@map("medication_category")
}

model InventoryMovement {
  id           String       @id @default(uuid())
  tenantId     String
  medicationId String
  userId       String?
  type         MovementType
  quantity     Int
  reason       String?
  referenceId  String?
  createdAt    DateTime     @default(now())

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  medication Medication @relation(fields: [medicationId], references: [id])
  user       User?      @relation(fields: [userId], references: [id])

  @@map("inventory_movements")
}

enum MovementType {
  entrada
  salida
  ajuste
  merma

  @@map("movement_type")
}

// ── PRESCRIPTIONS ─────────────────────────────────────────────
model Prescription {
  id           String   @id @default(uuid())
  tenantId     String
  patientId    String
  userId       String
  folio        String   @db.VarChar(30)
  issuedAt     DateTime @default(now()) @db.Date
  diagnosis    String?
  generalNotes String?
  sentWhatsapp Boolean  @default(false)
  createdAt    DateTime @default(now())

  tenant  Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patient Patient            @relation(fields: [patientId], references: [id])
  user    User               @relation(fields: [userId], references: [id])
  items   PrescriptionItem[]

  @@unique([tenantId, folio])
  @@map("prescriptions")
}

model PrescriptionItem {
  id             String  @id @default(uuid())
  prescriptionId String
  medicationId   String?
  medicationName String  @db.VarChar(200)
  dose           String? @db.VarChar(100)
  frequency      String? @db.VarChar(100)
  durationDays   Int?
  route          String? @db.VarChar(50)
  instructions   String?
  sortOrder      Int     @default(0)

  prescription Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  medication   Medication?  @relation(fields: [medicationId], references: [id])

  @@map("prescription_items")
}

// ── CONSENT FORMS ─────────────────────────────────────────────
model ConsentForm {
  id            String        @id @default(uuid())
  tenantId      String
  patientId     String
  userId        String?
  folio         String        @db.VarChar(30)
  type          ConsentType
  procedureDesc String?
  status        ConsentStatus @default(pendiente)
  signedAt      DateTime?
  pdfUrl        String?
  createdAt     DateTime      @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patient Patient @relation(fields: [patientId], references: [id])
  user    User?   @relation(fields: [userId], references: [id])

  @@unique([tenantId, folio])
  @@map("consent_forms")
}

enum ConsentType {
  quirurgico
  anestesia
  vacunacion
  eutanasia
  hospitalizacion
  otro

  @@map("consent_type")
}

enum ConsentStatus {
  pendiente
  firmado
  rechazado

  @@map("consent_status")
}

// ── INVOICES ──────────────────────────────────────────────────
model Invoice {
  id            String                @id @default(uuid())
  tenantId      String
  patientId     String?
  userId        String?
  folio         String                @db.VarChar(30)
  status        InvoiceStatus         @default(pendiente)
  subtotal      Decimal               @default(0) @db.Decimal(12, 2)
  tax           Decimal               @default(0) @db.Decimal(12, 2)
  total         Decimal               @default(0) @db.Decimal(12, 2)
  paymentMethod InvoicePaymentMethod?
  issuedAt      DateTime              @default(now())
  paidAt        DateTime?
  notes         String?
  createdAt     DateTime              @default(now())

  tenant  Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patient Patient?      @relation(fields: [patientId], references: [id])
  user    User?         @relation(fields: [userId], references: [id])
  items   InvoiceItem[]

  @@unique([tenantId, folio])
  @@map("invoices")
}

model InvoiceItem {
  id            String  @id @default(uuid())
  invoiceId     String
  appointmentId String?
  description   String  @db.VarChar(300)
  quantity      Int     @default(1)
  unitPrice     Decimal @db.Decimal(10, 2)
  total         Decimal @db.Decimal(10, 2)
  sortOrder     Int     @default(0)

  invoice     Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id])

  @@map("invoice_items")
}

enum InvoiceStatus {
  borrador
  pendiente
  pagada
  cancelada

  @@map("invoice_status")
}

enum InvoicePaymentMethod {
  efectivo
  tarjeta
  transferencia
  otro

  @@map("invoice_payment_method")
}

// ── SYSTEM ALERTS ─────────────────────────────────────────────
model SystemAlert {
  id          String        @id @default(uuid())
  tenantId    String
  type        AlertType
  severity    AlertSeverity @default(info)
  title       String        @db.VarChar(300)
  body        String?
  referenceId String?
  resolved    Boolean       @default(false)
  resolvedAt  DateTime?
  createdAt   DateTime      @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("system_alerts")
}

enum AlertType {
  stock_bajo
  vencimiento
  vacuna_proxima
  control_pendiente
  otro

  @@map("alert_type")
}

enum AlertSeverity {
  info
  warning
  danger

  @@map("alert_severity")
}

// ── NOTIFICATIONS ─────────────────────────────────────────────
model Notification {
  id            String              @id @default(uuid())
  tenantId      String
  ownerId       String?
  appointmentId String?
  channel       NotificationChannel
  status        NotificationStatus  @default(pendiente)
  message       String?
  sentAt        DateTime?
  createdAt     DateTime            @default(now())

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  owner       Owner?       @relation(fields: [ownerId], references: [id])
  appointment Appointment? @relation(fields: [appointmentId], references: [id])

  @@map("notifications")
}

enum NotificationChannel {
  whatsapp
  email
  sms

  @@map("notification_channel")
}

enum NotificationStatus {
  enviado
  fallido
  pendiente

  @@map("notification_status")
}
